```gitignore
# =========================================================
# Kaptan Discord DM Cleaner
# Git Ignore Rules
# =========================================================

# -------------------------
# IDEs & Editors
# -------------------------
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.ntvs*
*.njsproj
*.sln
*.sw?
*.code-workspace

# -------------------------
# Operating System Files
# -------------------------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# -------------------------
# Logs
# -------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -------------------------
# Node / Dependencies
# -------------------------
node_modules/

# -------------------------
# Temporary Files
# -------------------------
*.tmp
*.temp
*.bak
*.old
*.orig

# -------------------------
# Build / Cache
# -------------------------
dist/
build/
.cache/
coverage/

# -------------------------
# Local Testing Files
# -------------------------
test_server.js
test_results.png
verification_results*.png

# Development documents
walkthrough.md
implementation_plan.md
task.md

# Temporary artifacts
artifacts/

# -------------------------
# Archive Files
# -------------------------
*.zip
*.7z
*.rar

# -------------------------
# Environment Files
# -------------------------
.env
.env.local
.env.*

# -------------------------
# Package Manager Locks
# (Kaldırmak istersen sil)
# -------------------------
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
```
