```json
{
  "manifest_version": 3,

  "name": "__MSG_extensionName__",
  "short_name": "Kaptan DM",
  "description": "__MSG_extensionDesc__",
  "version": "5.1.0",
  "default_locale": "en",
  "author": "Kaptanbey0",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://discord.com/*",
    "https://*.discord.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://discord.com/*",
        "https://*.discord.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "inject.js",
        "content.css"
      ],
      "matches": [
        "https://discord.com/*",
        "https://*.discord.com/*"
      ]
    }
  ]
}
```
